# Cloudflare account that owns the RealtimeKit app.
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id

# RealtimeKit app identifier from the Cloudflare dashboard/API.
REALTIMEKIT_APP_ID=replace-with-realtimekit-app-id

# Participant preset configured in RealtimeKit.
REALTIMEKIT_PRESET_NAME=replace-with-preset-name

# Server-only Cloudflare API token used by the Worker to call RealtimeKit REST APIs.
# Never expose this value to browser code, Vite env variables, logs, or API responses.
CLOUDFLARE_API_TOKEN=replace-with-server-only-token

# Public origin for callback URLs such as webhook registration.
PUBLIC_BASE_URL=http://localhost:8787
